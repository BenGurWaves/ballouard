# ============================================================
# AI Web Agency — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# --- LLM Providers ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Lead Research ---
# Google Maps / Places API (for finding businesses)
GOOGLE_MAPS_API_KEY=
# Google PageSpeed Insights (for website auditing)
GOOGLE_PAGESPEED_API_KEY=
# SerpAPI (alternative for Google search results)
SERPAPI_KEY=

# --- Email Outreach ---
# SendGrid (primary email sender)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@youragency.com
SENDGRID_FROM_NAME=Your Agency Name
# Alternatively: SMTP direct
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Email warmup service (e.g. Instantly)
INSTANTLY_API_KEY=

# --- Payments ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# --- Messaging (Client Success) ---
# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
# Telegram Bot
TELEGRAM_BOT_TOKEN=
# Twilio (SMS fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Web Design Agent ---
# Vercel (for deploying built sites)
VERCEL_TOKEN=
VERCEL_TEAM_ID=
# GitHub (for storing site repos)
GITHUB_TOKEN=
GITHUB_ORG=

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./agency.db

# --- General ---
AGENCY_NAME=YourAgencyName
AGENCY_DOMAIN=youragency.com
LOG_LEVEL=INFO
